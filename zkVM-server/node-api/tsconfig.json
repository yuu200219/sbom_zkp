{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    
    "module": "nodenext",
    "target": "esnext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "moduleDetection": "force"
  },
  "include": [
    "src/**/*", 
    "scripts/**/*",
    "src/types.ts"  ],
  "exclude": ["node_modules", "dist"]
}